<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Interactive Map</title>

  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
  <link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster/dist/MarkerCluster.css" />

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #0b0b0b;
      color: white;
    }

    .content {
      padding: 30px;
    }

    #map {
      height: 650px;
      margin-top: 20px;
    }

    select, button {
      padding: 8px;
      background: #111;
      color: white;
      border: 1px solid #333;
      cursor: pointer;
    }

    .active {
      background: #c1121f;
    }
  </style>
</head>

<body>

<div class="content">
  <h1>Interactive Map</h1>

  <select id="yearFilter">
    <option value="all">All Years</option>
    <option value="2025">2025</option>
    <option value="2024">2024</option>
    <option value="2023">2023</option>
    <option value="2022">2022</option>
  </select>

  <button id="markerBtn" class="active">Markers</button>
  <button id="heatBtn">Heatmap</button>
  <button id="densityBtn">Neighbourhoods</button>

  <div id="map"></div>
</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster/dist/leaflet.markercluster.js"></script>
<script src="https://unpkg.com/leaflet.heat/dist/leaflet-heat.js"></script>

<script>
  var map = L.map('map').setView([-32.95, -60.66], 11);

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

  var markerCluster = L.markerClusterGroup();
  var heatLayer = L.heatLayer([], { radius: 25 });

  var barriosLayer;
  var allData = [];
  var barriosData;
  var mode = "markers";

  map.addLayer(markerCluster);

  function getColor(d) {
    return d > 20 ? '#800026' :
           d > 10 ? '#BD0026' :
           d > 5  ? '#E31A1C' :
           d > 2  ? '#FC4E2A' :
           d > 1  ? '#FD8D3C' :
                    '#FEB24C';
  }

  function loadMarkers(year) {
    markerCluster.clearLayers();

    allData.forEach(e => {
      if (!e.lat || !e.lng) return;

      if (year === "all" || String(e.year) === year) {
        var m = L.marker([e.lat, e.lng])
          .bindPopup(e.description || "No description");

        markerCluster.addLayer(m);
      }
    });

    map.addLayer(markerCluster);
  }

  function loadHeat(year) {
    var points = [];

    allData.forEach(e => {
      if (!e.lat || !e.lng) return;

      if (year === "all" || String(e.year) === year) {
        points.push([e.lat, e.lng, e.fatalities || 1]);
      }
    });

    heatLayer.setLatLngs(points);
    map.addLayer(heatLayer);
  }

  function loadDensity(year) {
    if (!barriosData) return;

    // conta eventi per quartiere
    var counts = {};

    barriosData.features.forEach(b => {
      counts[b.properties.BARRIO] = 0;
    });

    allData.forEach(e => {
      if (!e.lat || !e.lng) return;

      if (year !== "all" && String(e.year) !== year) return;

      barriosData.features.forEach(b => {
        if (inside([e.lng, e.lat], b.geometry)) {
          counts[b.properties.BARRIO]++;
        }
      });
    });

    if (barriosLayer) {
      map.removeLayer(barriosLayer);
    }

    barriosLayer = L.geoJSON(barriosData, {
      style: function(feature) {
        return {
          fillColor: getColor(counts[feature.properties.BARRIO]),
          weight: 1,
          color: "#333",
          fillOpacity: 0.7
        };
      },
      onEachFeature: function(feature, layer) {
        layer.bindPopup(
          feature.properties.BARRIO + "<br>Events: " + counts[feature.properties.BARRIO]
        );
      }
    });

    map.addLayer(barriosLayer);
  }

  // funzione punto dentro poligono
  function inside(point, vs) {
    var x = point[0], y = point[1];
    var inside = false;
    for (var i = 0, j = vs.coordinates[0].length - 1; i < vs.coordinates[0].length; j = i++) {
      var xi = vs.coordinates[0][i][0], yi = vs.coordinates[0][i][1];
      var xj = vs.coordinates[0][j][0], yj = vs.coordinates[0][j][1];

      var intersect = ((yi > y) != (yj > y))
          && (x < (xj - xi) * (y - yi) / (yj - yi) + xi);
      if (intersect) inside = !inside;
    }
    return inside;
  }

  function update() {
    map.eachLayer(l => {
      if (l !== map._layers[Object.keys(map._layers)[0]]) {
        map.removeLayer(l);
      }
    });

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

    var year = document.getElementById("yearFilter").value;

    if (mode === "markers") loadMarkers(year);
    if (mode === "heat") loadHeat(year);
    if (mode === "density") loadDensity(year);
  }

  fetch("data.json").then(r => r.json()).then(d => {
    allData = d;
    update();
  });

  fetch("barrios.geojson").then(r => r.json()).then(b => {
    barriosData = b;
  });

  document.getElementById("yearFilter").onchange = update;

  document.getElementById("markerBtn").onclick = function() {
    mode = "markers"; update();
  };

  document.getElementById("heatBtn").onclick = function() {
    mode = "heat"; update();
  };

  document.getElementById("densityBtn").onclick = function() {
    mode = "density"; update();
  };

</script>

</body>
</html>
